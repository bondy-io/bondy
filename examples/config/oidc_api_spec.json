{
    "id": "OIDC Test",
    "name": "Longpoll & SSE",
    "host": "_",
    "realm_uri": "com.leapsight.test",
    "status_codes": {
        "bondy.error.badarg": 400,
        "bondy.error.not_found": 404,
        "bondy.error.already_exists": 400,
        "wamp.error.no_such_procedure": 404
    },
    "variables": {
        "oidc": {
            "type": "oidc",
            "provider": "${OIDC_PROVIDER_ID}"
        },
        "schemes": [
            "https"
        ],
        "headers": {
            "access-control-allow-origin": "*",
            "access-control-allow-credentials": "true",
            "access-control-allow-methods": "GET,HEAD,PUT,PATCH,POST,DELETE",
            "access-control-allow-headers": "origin,x-requested-with,content-type,accept,x-csrf-token",
            "access-control-max-age": "86400"
        }
    },
    "defaults": {
        "retries": 0,
        "timeout": 15000,
        "connect_timeout": 5000,
        "schemes": "{{variables.schemes}}",
        "headers": "{{variables.headers}}",
        "security": "{{variables.oidc}}"
    },
    "versions": {
        "1.0.0": {
            "base_path": "/api-oicd/[v1.0]",
            "languages": ["en"],
            "paths": {}
        }
    }
}
